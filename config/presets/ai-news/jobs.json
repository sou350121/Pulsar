{
  "_comment": "AI News preset — minimal 4-job pipeline. setup.sh / quickstart.sh substitutes /home/admin -> $HOME before installing into ~/.openclaw/cron/jobs.json.",
  "jobs": [
    {
      "id": "0d503792-3801-4f69-8484-a59b58846ddc",
      "agentId": "reports",
      "name": "AI News — RSS Collect",
      "enabled": true,
      "schedule": {
        "kind": "cron",
        "expr": "0 7 * * *",
        "tz": "Asia/Shanghai"
      },
      "sessionTarget": "isolated",
      "wakeMode": "next-heartbeat",
      "payload": {
        "kind": "agentTurn",
        "message": "你是「AI News RSS Collect」定时任务。严格执行：\n1) 运行：timeout 300 python3 /home/admin/clawd/scripts/ai-app-rss-collect.py\n2) 退出码0=正常，非0=错误\n3) 脚本执行完毕后绝对静默",
        "deliver": false,
        "channel": "telegram",
        "to": "YOUR_TELEGRAM_CHAT_ID",
        "model": "alibaba-cloud/qwen3.5-plus",
        "bestEffortDeliver": true
      },
      "timeoutMs": 360000
    },
