# Pulsar / 照見 — Environment Variables
# Copy to .env and fill in your values

# LLM API Key
# All Pulsar LLM calls use OpenAI-compatible format.
# Works with any provider: OpenAI, DeepSeek, Moonshot, DashScope (Alibaba), Groq, self-hosted, etc.
# Default reference deployment uses DashScope + qwen3.5-plus.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# GitHub Token
# Needs: repo write access to your knowledge-base repo(s)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx

# Telegram Bot Token
# Create via @BotFather
TELEGRAM_BOT_TOKEN=xxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Chat ID (target channel/user)
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# Moltbot Gateway
# The gateway must be running before cron jobs execute
MOLTBOT_GATEWAY_PORT=18789

# Tophub Data API Key
# Used by ai-app-rss-collect.py to fetch trending tech articles (optional)
# Get from https://www.tophubdata.com/
TOPHUB_API_KEY=your_tophubdata_api_key
