# Pulsar / 照見 — Environment Variables
# Copy to .env and fill in your values

# LLM API Key
# All Pulsar LLM calls use OpenAI-compatible format.
# Works with any provider: OpenAI, DeepSeek, Moonshot, DashScope (Alibaba), Groq, self-hosted, etc.
# Default reference deployment uses DashScope + qwen3.5-plus.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# GitHub Token
# Needs: repo write access to your knowledge-base repo(s)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx

# Telegram Bot Token
# Create via @BotFather
TELEGRAM_BOT_TOKEN=xxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Chat ID (target channel/user)
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# Moltbot Gateway
# The gateway must be running before cron jobs execute
MOLTBOT_GATEWAY_PORT=18789

# Tophub Data API Key
# Used by ai-app-rss-collect.py to fetch trending tech articles (optional)
# Get from https://www.tophubdata.com/
TOPHUB_API_KEY=your_tophubdata_api_key

# ── Path overrides (optional) ────────────────────────────────────────────────
# By default, scripts read/write under /home/admin/clawd/. Set these to relocate
# without rewriting hardcoded paths.

# Root for all runtime memory files (rss/*.json, hotspots, watchdog log, etc.)
# PULSAR_MEMORY_DIR=/home/you/clawd/memory

# Where mcp_server.py looks for sibling helpers (_domain_loader.py,
# semantic-search.py); auto-detected from the script's own path if unset.
# PULSAR_SCRIPTS_DIR=/home/you/clawd/scripts

# ── GitHub Issues Adoption Sensor (optional) ─────────────────────────────────
# update-gh-field-notes.py / prep-community-context.py push the adoption
# snapshot back into your knowledge-base. Defaults target the reference
# VLA-Handbook deployment — override these for your own domain.
# PULSAR_FIELD_NOTES_REPO=your-username/your-domain-handbook
# PULSAR_FIELD_NOTES_PATH=deployment/community_field_notes_github.md

# Colon-separated list of .env files prep-community-context.py searches for
# GITHUB_TOKEN (in addition to process env). Useful when your token lives in
# a separate gateway env file.
# PULSAR_ENV_PATHS=/home/you/.clawdbot/.env:/home/you/.moltbot/.env
