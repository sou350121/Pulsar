# Pulsar / 照見 — Environment Variables
# Copy to .env and fill in your values

# DashScope (Alibaba Cloud) API Key
# Used by all LLM calls (qwen3.5-plus, qwen-max)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# GitHub Token
# Needs: repo write access to VLA-Handbook and Agent-Playbook
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx

# Telegram Bot Token
# Create via @BotFather
TELEGRAM_BOT_TOKEN=xxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Chat ID (target channel/user)
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# Moltbot Gateway
# The gateway must be running before cron jobs execute
MOLTBOT_GATEWAY_PORT=18789

# Tophub Data API Key
# Used by ai-app-rss-collect.py to fetch trending tech articles
# Get from https://www.tophubdata.com/
TOPHUB_API_KEY=your_tophubdata_api_key
